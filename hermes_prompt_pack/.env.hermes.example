# =============================================================================
# Hermes Compliance Framework — Environment Variable Template
# =============================================================================
# This file IS committed to source control. It documents required variables.
# The actual .env.hermes file is gitignored and NEVER committed.
#
# Setup:
#   cp .env.hermes.example .env.hermes
#   # Then populate each variable below in .env.hermes
#
# HERMES_API_KEY generation (cryptographically random, 256-bit):
#   openssl rand -hex 32
#
# For multi-tenant Phase 3: HERMES_API_KEY will be replaced by a JWT
# signing secret or Vault-issued ephemeral credential per SP 800-207.
# =============================================================================

# Required: API authentication key for /v1/scrub endpoint
# Must be at least 32 hex characters (128-bit minimum; 64 hex / 256-bit recommended)
HERMES_API_KEY=REPLACE_WITH_OUTPUT_OF__openssl_rand_-hex_32
